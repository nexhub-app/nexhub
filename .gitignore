# =====================================================================
# 官方 Dart 模板（来源：github/gitignore — Dart.gitignore）
# https://github.com/github/gitignore/blob/main/Dart.gitignore
# =====================================================================
# See https://www.dartlang.org/guides/libraries/private-files

# Files and directories created by pub
.dart_tool/
.packages
build/
# 注意：本仓库是一个 Flutter「应用」（而非库），为可复现构建，保留 pubspec.lock，故不忽略。

# Directory created by dartdoc
# If you don't generate documentation locally you can remove this line.
doc/api/

# dotenv environment variables file
.env*

# Avoid committing generated Javascript files:
*.dart.js
# Produced by the --dump-info flag.
*.info.json
# When generated by dart2js. Don't specify *.js if your
# project includes source files written in JavaScript.
*.js
*.js_
*.js.deps
*.js.map

.flutter-plugins
.flutter-plugins-dependencies

# Flutter 生成产物（来自 GitHub 官方 Flutter.gitignore）
**/generated_plugin_registrant.*
**/generated_plugins.cmake
**/GeneratedPluginRegistrant.*
**/Generated.xcconfig
**/flutter_export_environment.sh
android/local.properties
linux/flutter/ephemeral/
macos/Flutter/ephemeral/
app.*.symbols
app.*.map.json
/android/app/debug
/android/app/profile
/android/app/release

# =====================================================================
# 通用 / 系统 / 编辑器 临时文件（Global 模板常用项）
# =====================================================================
*.class
*.log
*.pyc
*.swp
.DS_Store
Thumbs.db
desktop.ini
.atom/
.history
.svn/
.swiftpm/
.idea/
*.iml
*.ipr
*.iws
.build/
.buildlog/
migrate_working_dir/
#.vscode/   # 若希望将 VS Code 配置纳入版本控制，可取消注释此行

# =====================================================================
# NexHub 项目专用（共创模式）
# =====================================================================

# WorkBuddy 本地记忆与数据（不入库，仅本地使用）
.workbuddy/

# 捆绑的 Flutter SDK（从 flutter.zip 解压，约 1GB，不入库）
sdk/

# 安装包构建产物
/installer/

# ===== 共创模式：源不入库 =====
# 应用不内置/打包任何预备源；源由用户自行导入或在社区共享。
# 这些源 JSON 仅保留在开发者本地，绝不进入公开仓库。
plugins/builtin/*.json
reference/

# ===== 开发/探针/AI 工具产生的临时产物（不入库）=====
.probe_tmp/
.qoder/
.trae/
bz_author.html
bz_detail.html
goda_detail.html
goda_detail2.html

# ===== 根目录开发/探针/临时脚本（不入库）=====
net_check.*
probe_*.txt
probe_*.cmd
probe_*.ps1
probe_*.bat
run_*.cmd
run_*.ps1
run_*.bat
tmp_*.mjs

# ===== 内部开发文档 / 重开发计划（不入库）=====
# 这些是私有开发过程产物（含旧项目 PlexHub 引用与重开发提示词），
# 不进入公开仓库。整个 docs/ 目录均不入库。
docs/

# 内部源扫描脚本
tools/scan_golden_sources.py
tools/scan_golden_sources2.py
